// ============================================================
// BUNDAYAKIN — PRISMA SCHEMA
// Human Care Consulting · v1.1 · 17 Mei 2026
// Perubahan v1.1: hapus KTP, UnlockedNanny→ConnectionQuota, Midtrans→Mayar, tambah NannyMedia
// Stack: Next.js 14 + Prisma + Neon (PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  PARENT
  NANNY
  ADMIN
  PSIKOLOG
}

// Jenjang psikolog HCC — menentukan harga sesi Konsultasi Psikolog Anak (PRD 13 §4)
enum PsikologLevel {
  JUNIOR
  MID
  SENIOR
}

enum ConsultationBookingStatus {
  PENDING_PAYMENT  // slot dipegang sementara menunggu pembayaran Mayar
  CONFIRMED        // pembayaran sukses, sesi terjadwal
  COMPLETED        // sesi selesai dilakukan psikolog
  CANCELLED        // pembayaran gagal/expired, atau dibatalkan
}

enum SubscriptionStatus {
  INACTIVE    // belum bayar
  ACTIVE      // langganan aktif
  EXPIRED     // kadaluarsa
  CANCELLED
}

enum MatchingStatus {
  PENDING         // survey belum lengkap dari salah satu pihak
  PROCESSING      // AI sedang scoring
  COMPLETED       // hasil matching sudah ada
  NEGOTIATING     // ada dealbreaker, sedang dinegosiasi
  ACCEPTED        // orang tua terima nanny
  REJECTED        // orang tua tolak / auto-reject setelah deadline
  EXPIRED         // masa eksklusif habis, nanny masuk talent pool
}

enum NannyType {
  LIVE_IN         // tinggal di rumah
  LIVE_OUT        // tidak menginap
  INFAL           // infal / pengganti
  TEMPORARY       // sementara / kontrak singkat
}

enum WorkScope {
  CHILD_ONLY
  ELDERLY_ONLY
  CHILD_AND_ELDERLY
  HOUSEHOLD_INCLUDED
}

enum ChildAgeGroup {
  INFANT_0_6M     // 0–6 bulan
  INFANT_6_12M    // 6–12 bulan
  TODDLER_1_3Y    // 1–3 tahun
  PRESCHOOL_3_6Y  // 3–6 tahun
  MIXED           // lebih dari satu rentang usia
}

enum EvaluationTiming {
  WEEK_1
  WEEK_2
  MONTH_1
  MONTH_3
  QUARTERLY
}

enum EvaluationStatus {
  PENDING
  PARENT_DONE
  NANNY_DONE
  COMPLETED
}

enum TransactionType {
  SUBSCRIPTION          // Rp 500rb/tahun
  ADDON_PSIKOTES        // Layer 2 — Rp 300rb
  ADDON_PSIKOLOG        // Layer 3 — Rp 1.2–1.5 juta
  ADDON_TRACK_RECORD    // akses rekam jejak — Rp 50rb
  CONNECTION_ADDON      // Rp 100rb — buka koneksi setelah kuota habis (via Mayar)
  PLACEMENT_FEE         // fee penyaluran nanny
  CONSULTATION_PSIKOLOG_ANAK // Konsultasi Psikolog Anak (Tumbuh Kembang Tahap 2) — harga per level, lihat PRD 13 §4/§7b
}

enum NannyMediaType {
  AVATAR
  INTRO_VIDEO       // video perkenalan (max 3 menit, CF Stream)
  SKILL_VIDEO       // video keahlian (max 3 menit, CF Stream)
  PORTFOLIO_PHOTO   // foto masakan & keahlian (CF R2)
}

enum ConnectionFlowType {
  REFERRAL      // Flow A — nanny diundang parent via kode referral
  TALENT_POOL   // Flow B — AI rekomendasikan dari pool
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
  REFUNDED
}

enum AssessmentLayer {
  LAYER_1   // survey kecocokan — gratis dalam langganan
  LAYER_2   // + psikotes AI
  LAYER_3   // + psikolog
}

enum CheckinStatus {
  PENDING
  COMPLETED
}

enum SocialMediaFlag {
  NONE
  FLAGGED
  REVIEWED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

// Kunci konfigurasi harga & kuota yang bisa diatur admin (Pricing Config Panel)
enum PricingConfigKey {
  SUBSCRIPTION_FEE_IDR      // Langganan tahunan
  PLACEMENT_FEE_IDR         // Biaya penempatan nanny
  CONNECTION_ADDON_FEE_IDR  // Beli koneksi tambahan setelah kuota habis (Flow A/Referral)
  REFERRAL_QUOTA            // Kuota undangan (Flow A) per 30 hari — berlaku semua akun
  TALENT_POOL_QUOTA         // Kuota Talent Pool (Flow B) per 30 hari — khusus pelanggan (dipakai untuk akses direktori, BUKAN lagi unlock kontak gratis — lihat TALENT_POOL_CONTACT_FEE_IDR)
  TALENT_POOL_CONTACT_FEE_IDR // Buka nomor WA nanny dari AI Talent Pool — SELALU berbayar per kontak, tidak pernah gratis lewat kuota (keputusan Kartika, Juli 2026)

  // Konsultasi Psikolog Anak (PRD 13 §7b, 8 Juli 2026) — 4 key disiapkan sekaligus
  // walau Junior & Senior belum dibuka untuk dibeli (keputusan Kartika eksplisit,
  // beda dari prinsip default ADR-008); hanya admin yang melihat panel ini.
  CONSULTATION_JUNIOR_FEE_IDR   // belum dijual saat peluncuran
  CONSULTATION_MID_FEE_IDR      // harga peluncuran — satu-satunya yang dijual saat ini
  CONSULTATION_SENIOR_FEE_IDR   // belum dijual saat peluncuran
  CONSULTATION_CUSTOMER_FEE_IDR // harga khusus pelanggan, hanya berlaku untuk tarif Mid saat ini

  ADDON_PSIKOTES_FEE_IDR // Layer 2 — buka hasil Psikotes AI (Capture Work Style) untuk 1 nanny
}

// ============================================================
// AUTH — NextAuth v5
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// USER — core identity (parent & nanny)
// ============================================================

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  phone          String?   @unique
  image          String?
  hashedPassword String?   // untuk credentials login
  role           UserRole  @default(PARENT)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Role-specific profiles (1-to-1)
  parentProfile   ParentProfile?
  nannyProfile    NannyProfile?
  psikologProfile PsikologProfile?

  // Notifications & activity
  notifications Notification[]
  activityLogs  ActivityLog[]

  // Pricing Config — perubahan harga/kuota yang dijadwalkan/dibatalkan oleh admin ini
  pricingConfigScheduled PricingConfigEntry[] @relation("PricingConfigScheduledBy")
  pricingConfigCancelled PricingConfigEntry[] @relation("PricingConfigCancelledBy")

  @@index([email])
  @@index([role])
}

// ============================================================
// PARENT PROFILE
// ============================================================

model ParentProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  fullName        String
  province        String?  // provinsi
  city            String?
  district        String?  // kecamatan
  address         String?  @db.Text
  profilePhotoUrl String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Children & elderly under care
  children  ChildProfile[]
  elderlies ElderlyProfile[]

  // Consent UU PDP No. 27/2022
  consentGivenAt      DateTime?

  // Survey
  surveyAnswers       Json?              // snapshot SurveyAnswers dari SurveyForm
  surveyCompletedAt   DateTime?

  // Subscription
  subscription Subscription?

  // Matching
  matchingRequests MatchingRequest[]

  // Survey responses
  surveyResponses SurveyResponse[]

  // Evaluations (as employer)
  evaluations Evaluation[]

  // Nanny assignments (active)
  nannyAssignments NannyAssignment[]

  // Track record access purchased
  trackRecordAccess TrackRecordAccess[]

  // Kuota Koneksi (rolling 30-day window)
  connectionQuotas ConnectionQuota[]

  // Referrals given by this parent
  referralsGiven ParentReferral[]

  // Match results (Sprint 2 direktori)
  matchResults MatchResult[]

  // Jaminan Kecocokan
  matchGuarantees MatchGuarantee[]

  // Rekam jejak yang ditulis parent ini
  trackRecordsWritten TrackRecordEntry[]

  // Konsultasi Psikolog Anak (Tumbuh Kembang Tahap 2)
  consultationBookings ConsultationBooking[]
  consultationReviews  ConsultationReview[]

  @@index([userId])
}

// ============================================================
// CHILD PROFILE
// ============================================================

model ChildProfile {
  id              String         @id @default(cuid())
  parentProfileId String
  name            String
  dateOfBirth     DateTime
  ageGroup        ChildAgeGroup
  gender          String?
  profilePhotoUrl String?
  allergies       String?        @db.Text  // narasi bebas
  medicalNotes    String?        @db.Text  // kondisi kesehatan khusus
  pantangan       String?        @db.Text  // pantangan makanan / aktivitas
  schedule        String?        @db.Text  // jadwal harian (narasi)
  schoolName      String?
  schoolSchedule  String?
  additionalNotes String?        @db.Text
  nannyNotes      String?        @db.Text  // catatan dari nanny — hanya bisa diisi nanny, tidak diedit orang tua
  caraMenenangkan String?        @db.Text  // cara menenangkan saat rewel
  doList          String[]                 // hal yang boleh/perlu dilakukan nanny
  dontList        String[]                 // hal yang tidak boleh dilakukan nanny
  sortOrder       Int            @default(0) // urutan tampil multi-anak

  // Usia kehamilan saat lahir (minggu) — dipakai untuk usia koreksi KPSP jika ≤35 minggu (Tahap 2)
  gestationalWeeksAtBirth Int?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  parentProfile ParentProfile  @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  assignments   AssignmentChild[]

  // Tumbuh Kembang (PRD 13)
  growthRecords         GrowthRecord[]            // Tahap 1
  journalEntries        ChildJournalEntry[]        // Tahap 1
  developmentScreenings DevelopmentScreeningRecord[] // Tahap 2
  consultationBookings  ConsultationBooking[]        // Tahap 2

  @@index([parentProfileId])
}

// ============================================================
// GROWTH RECORD — pencatatan berat/tinggi/lingkar kepala anak
// Kurva Pertumbuhan (Tumbuh Kembang, PRD 13 Tahap 1)
// Pencatatan gratis; interpretasi kurva WHO khusus pelanggan (lihat src/lib/growth-standards.ts)
// ============================================================

model GrowthRecord {
  id                  String   @id @default(cuid())
  childProfileId      String
  measuredAt          DateTime
  weightKg            Float?
  heightCm            Float?
  headCircumferenceCm Float?
  notes               String?  @db.Text
  createdAt           DateTime @default(now())

  childProfile ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  @@index([childProfileId])
  @@index([measuredAt])
}

// ============================================================
// CHILD JOURNAL ENTRY — jurnal momen anak (teks + foto opsional)
// Tumbuh Kembang, PRD 13 Tahap 1. authorRole disiapkan untuk Tahap 4
// (Log Harian Nanny) — Tahap 1 hanya diisi orang tua.
// ============================================================

model ChildJournalEntry {
  id             String   @id @default(cuid())
  childProfileId String
  authorUserId   String
  authorRole     String   // "PARENT" | "NANNY" (Tahap 4)
  caption        String   @db.Text
  photoUrl       String?
  photoKey       String?  // R2 object key (untuk hapus foto nanti)
  momentDate     DateTime @default(now())
  createdAt      DateTime @default(now())

  childProfile ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  @@index([childProfileId])
  @@index([momentDate])
}

// ============================================================
// DEVELOPMENT SCREENING RECORD — Skrining Perkembangan (KPSP)
// Tumbuh Kembang, PRD 13 Tahap 2. Instrumen & skoring resmi:
// lihat src/lib/kpsp-instrument.ts & src/lib/kpsp-scoring.ts.
// Model terpisah dari SurveyResponse (Matching Engine) — lihat
// CLAUDE.md keputusan 5 Juli 2026 & ADR terkait.
// ============================================================

model DevelopmentScreeningRecord {
  id             String   @id @default(cuid())
  childProfileId String
  screeningDate  DateTime
  ageMonthsUsed  Int      // usia (bulan) setelah pembulatan/koreksi prematur — dipakai memilih formulir
  ageBand        Int      // salah satu dari KPSP_AGE_BANDS (3,6,...,72)
  answers        Json     // boolean[] sesuai urutan KPSP_QUESTIONNAIRES[ageBand]
  yaCount        Int
  category       String   // "SESUAI" | "MERAGUKAN" | "PENYIMPANGAN"
  createdAt      DateTime @default(now())

  childProfile ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  @@index([childProfileId])
  @@index([screeningDate])
}

// ============================================================
// PSIKOLOG PROFILE — Portal Psikolog (PRD 13 §3b/§7b, ADR-010)
// Akun dibuat manual oleh tim HCC (bukan pendaftaran mandiri) setelah
// screening — pola sama seperti akun ADMIN.
// ============================================================

model PsikologProfile {
  id            String        @id @default(cuid())
  userId        String        @unique
  fullName      String
  level         PsikologLevel
  isActive      Boolean       @default(true)
  // Kapasitas sesi/hari — default 3 (nyaman), maksimum 5 (PRD 13 §7 keputusan 2).
  // Nilai per-psikolog, bukan config global — tidak lewat Pricing Config Panel.
  dailyCapacity Int           @default(3)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  consultationBookings ConsultationBooking[]
  weeklySchedule       PsikologWeeklySchedule[]
  cutiDates            PsikologCuti[]
  reviews              ConsultationReview[]

  @@index([userId])
  @@index([level])
  @@index([isActive])
}

// ============================================================
// JADWAL PSIKOLOG — pola mingguan berulang per psikolog (ADR-012, 11 Juli 2026)
// Tidak ada baris = tutup. Kombinasi hari (0-6) x 3 Slot Konsultasi baku,
// maks 21 baris/psikolog. Cuti (PsikologCuti) menang mutlak atas pola ini.
// ============================================================

model PsikologWeeklySchedule {
  id         String   @id @default(cuid())
  psikologId String
  dayOfWeek  Int      // 0=Minggu..6=Sabtu (JS Date.getUTCDay())
  slotTime   String   // "09:00" | "13:00" | "16:00" — lihat CONSULTATION_SLOT_TIMES
  isOpen     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  psikolog PsikologProfile @relation(fields: [psikologId], references: [id], onDelete: Cascade)

  @@unique([psikologId, dayOfWeek, slotTime])
  @@index([psikologId])
}

model PsikologCuti {
  id         String   @id @default(cuid())
  psikologId String
  cutiDate   DateTime @db.Date
  reason     String?
  createdAt  DateTime @default(now())

  psikolog PsikologProfile @relation(fields: [psikologId], references: [id], onDelete: Cascade)

  @@unique([psikologId, cutiDate])
  @@index([psikologId])
}

// ============================================================
// CONSULTATION BOOKING — Konsultasi Psikolog Anak (PRD 13 §3b/§7b)
// Booking pakai Slot Konsultasi tetap (lihat CONTEXT.md) — jam sama untuk
// semua psikolog. Unique constraint [psikologId, bookingDate, slotTime]
// mencegah dua booking rebutan slot yang sama (race condition dua parent
// booking bersamaan — lihat catatan review di handoff).
// ============================================================

model ConsultationBooking {
  id             String                    @id @default(cuid())
  parentProfileId String
  childProfileId String
  psikologId     String
  transactionId  String?                   @unique

  // Snapshot harga saat booking dibuat — tidak berubah walau config di-update nanti
  level          PsikologLevel
  priceIDR       Int

  bookingDate    DateTime                  @db.Date
  slotTime       String                    // "09:00", "13:00", "16:00" — lihat CONSULTATION_SLOT_TIMES
  status         ConsultationBookingStatus @default(PENDING_PAYMENT)

  // Asal eskalasi dari Skrining Perkembangan (opsional — booking bisa juga dibuat langsung)
  sourceScreeningId String?

  // Catatan hasil sesi dari psikolog untuk orang tua — tidak boleh diubah/diparafrase sistem
  psychologistNotes String?                @db.Text
  completedAt       DateTime?

  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  parentProfile ParentProfile   @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  childProfile  ChildProfile    @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  psikolog      PsikologProfile @relation(fields: [psikologId], references: [id])
  review        ConsultationReview?

  @@unique([psikologId, bookingDate, slotTime])
  @@index([parentProfileId])
  @@index([childProfileId])
  @@index([psikologId, bookingDate])
  @@index([psikologId, status])
  @@index([status])
}

// ============================================================
// ULASAN PSIKOLOG — internal-only, pemantauan kualitas HCC (ADR-012, 11 Juli 2026)
// JANGAN PERNAH select field-field di sini dari endpoint yang bisa diakses
// PARENT/PSIKOLOG — hanya boolean "punya review atau tidak" boleh bocor ke situ.
// ============================================================

model ConsultationReview {
  id              String   @id @default(cuid())
  bookingId       String   @unique
  parentProfileId String
  psikologId      String
  isGood          Boolean
  scores          Json?    // { kejelasan_penjelasan: "Baik", empati: "Cukup", ... }
  narrative       String?  @db.Text
  createdAt       DateTime @default(now())

  booking       ConsultationBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  parentProfile ParentProfile       @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  psikolog      PsikologProfile     @relation(fields: [psikologId], references: [id])

  @@index([psikologId])
}

// ============================================================
// ELDERLY PROFILE (lansia — Phase 2, schema disiapkan sekarang)
// ============================================================

model ElderlyProfile {
  id              String   @id @default(cuid())
  parentProfileId String
  name            String
  dateOfBirth     DateTime?
  gender          String?
  medicalNotes    String?  @db.Text
  mobilityNotes   String?  @db.Text  // kemampuan mobilitas
  dietaryNotes    String?  @db.Text
  medicationNotes String?  @db.Text
  additionalNotes String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parentProfile ParentProfile @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)

  @@index([parentProfileId])
}

// ============================================================
// NANNY PROFILE
// ============================================================

model NannyProfile {
  id                  String             @id @default(cuid())
  userId              String             @unique
  fullName            String
  dateOfBirth         DateTime?
  gender              String?            @default("Perempuan")
  province            String?            // provinsi
  city                String?
  district            String?
  address             String?            @db.Text
  profilePhotoUrl     String?            // R2 public URL

  // Work preferences
  nannyType           NannyType[]        // bisa multi: live-in + infal
  workScope           WorkScope?
  preferredAgeGroup   ChildAgeGroup[]
  availableFrom       DateTime?
  expectedSalaryMin   Int?               // IDR
  expectedSalaryMax   Int?               // IDR

  // Background
  educationLevel      String?
  yearsOfExperience   Int?               @default(0)
  previousFamilies    Int?               @default(0)  // jumlah keluarga sebelumnya
  bio                 String?            @db.Text
  skills              String[]           // ["MPASI", "bayi kolik", "toilet training", ...]
  languages           String[]           // ["Indonesia", "Sunda", "Jawa"]
  religion            String?
  dressCode           String?            // preferensi pakaian kerja

  // References
  referenceCount      Int?               @default(0)
  references          NannyReference[]

  // Social media screening
  socialMediaFlag     SocialMediaFlag    @default(NONE)
  socialMediaNotes    String?            @db.Text

  // Badges & reputation
  badges              String[]           // ["Terpercaya", "Terverifikasi", ...]
  reputationScore     Float?             @default(0)

  // Consent UU PDP No. 27/2022
  consentGivenAt      DateTime?

  // Survey
  surveyAnswers       Json?              // snapshot SurveyAnswers dari SurveyForm
  surveyCompletedAt   DateTime?

  // LinkedIn mode — nanny aktif cari keluarga baru
  openToJob           Boolean            @default(false)

  // Availability
  isAvailable         Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Matching
  matchingRequests MatchingRequest[]
  matchingResults  MatchingResult[]

  // Evaluations (as employee)
  evaluations Evaluation[]

  // Assignments
  nannyAssignments NannyAssignment[]

  // Survey responses
  surveyResponses SurveyResponse[]

  // Psikotes & assessment results
  assessmentResults AssessmentResult[]

  // Track record
  trackRecordEntries TrackRecordEntry[]

  // Media portfolio (foto & video)
  media NannyMedia[]

  // Portfolio pengalaman kerja (entri teks + foto)
  portfolios NannyPortfolio[]

  // Referral
  referralsGiven    Referral[] @relation("ReferrerNanny")

  // Match results (direktori & kuota koneksi)
  matchResults MatchResult[]

  @@index([userId])
  @@index([isAvailable])
  @@index([openToJob])
  @@index([city])
}

// ============================================================
// NANNY REFERENCE (rekam jejak dari keluarga sebelumnya)
// ============================================================

model NannyReference {
  id             String   @id @default(cuid())
  nannyProfileId String
  employerName   String?  // anonim jika tidak opt-in
  employerPhone  String?
  durationMonths Int?
  workPeriod     String?  // "Jan 2023 – Mar 2024"
  notes          String?  @db.Text
  isPublic       Boolean  @default(false) // opt-in dari pemberi kerja
  createdAt      DateTime @default(now())

  nannyProfile NannyProfile @relation(fields: [nannyProfileId], references: [id], onDelete: Cascade)

  @@index([nannyProfileId])
}

// ============================================================
// SUBSCRIPTION — Rp 500rb/tahun untuk parent
// ============================================================

model Subscription {
  id              String             @id @default(cuid())
  parentProfileId String             @unique
  status          SubscriptionStatus @default(INACTIVE)
  planName        String             @default("BundaYakin Annual")
  priceIDR        Int                @default(500000)
  startDate       DateTime?
  endDate         DateTime?
  autoRenew       Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  parentProfile ParentProfile  @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  transactions  Transaction[]

  @@index([parentProfileId])
  @@index([status])
}

// ============================================================
// TRANSACTION — semua pembayaran
// ============================================================

model Transaction {
  id                 String            @id @default(cuid())
  subscriptionId     String?
  parentProfileId    String?           // siapa yang bayar
  nannyProfileId     String?           // nanny terkait (jika ada)
  type               TransactionType
  status             TransactionStatus @default(PENDING)
  amountIDR          Int
  mayarInvoiceId     String?           @unique  // ID invoice dari Mayar
  mayarPaymentUrl    String?           @db.Text // URL checkout Mayar
  mayarStatus        String?                    // status dari Mayar webhook
  paymentMethod      String?                    // "transfer", "qris", dll
  paidAt             DateTime?
  expiredAt          DateTime?
  notes              String?
  metadata           Json?             // data konteks tambahan (matchingRequestId, childIds, dll)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([mayarInvoiceId])
  @@index([status])
  @@index([parentProfileId])
}

// ============================================================
// MATCHING REQUEST — satu sesi matching parent ↔ nanny
// ============================================================

model MatchingRequest {
  id              String         @id @default(cuid())
  parentProfileId String
  nannyProfileId  String?        // null jika nanny belum dipilih (pool matching)
  layer           AssessmentLayer @default(LAYER_1)
  status          MatchingStatus  @default(PENDING)

  // Bagaimana koneksi ini terjadi
  connectionFlow  ConnectionFlowType? // REFERRAL (via kode) | TALENT_POOL

  // Survey completion flags
  parentSurveyDone  Boolean @default(false)
  nannySurveyDone   Boolean @default(false)

  // Periode eksklusif — nanny terikat ke orang tua ini selama X hari
  // Setelah exclusiveUntil lewat tanpa keputusan → auto-EXPIRED → nanny masuk talent pool
  exclusiveUntil  DateTime? // 7 hari dari createdAt (null = tidak ada periode eksklusif)
  extensionUsed   Boolean   @default(false) // apakah perpanjangan 3 hari sudah dipakai
  extensionUntil  DateTime? // diisi saat perpanjangan diaktifkan (exclusiveUntil + 3 hari)

  // Keputusan orang tua
  parentDecision  String?   // "ACCEPTED" | "REJECTED"
  decisionAt      DateTime? // kapan keputusan dibuat

  // Metadata
  nannyTypeRequested NannyType?
  workScopeRequested WorkScope?
  startDateRequested DateTime?
  notes              String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parentProfile ParentProfile @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  nannyProfile  NannyProfile? @relation(fields: [nannyProfileId], references: [id])

  // Survey responses
  surveyResponses SurveyResponse[]

  // Custom questions
  customQuestions CustomQuestion[]

  // Dealbreakers
  dealbreakers Dealbreaker[]

  // Result
  matchingResult MatchingResult?

  @@index([parentProfileId])
  @@index([nannyProfileId])
  @@index([status])
}

// ============================================================
// SURVEY QUESTIONS — master bank soal
// ============================================================

model SurveyQuestion {
  id          String   @id @default(cuid())
  code        String   @unique  // "A1.1", "A1.2", matches constants id
  domain      String            // "A", "B", "C"
  aspect      String            // "A1", "A2", "B1", dll
  aspectLabel String?           // "Gaji, Libur & Fasilitas"
  layer       String   @default("L1")   // "L1" | "L2" | "L2/L3"
  weight      String   @default("Menengah") // "Tinggi" | "Menengah" | "Rendah"
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  canBeDealbreaker Boolean @default(false)

  // Nanny side (always present)
  questionTextNanny      String   @db.Text
  optionsNanny           Json?    // [{value, label}]
  hasFreeTextNanny       Boolean  @default(false)
  freeTextTriggersNanny  String[]

  // Parent side (null = nanny-only question)
  questionTextParent      String?  @db.Text
  optionsParent           Json?    // [{value, label}]
  hasFreeTextParent       Boolean  @default(false)
  freeTextTriggersParent  String[]

  // Popup follow-up questions (JSON array of PopupFollowUp)
  popupFollowUp Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responses SurveyResponse[]

  @@index([domain])
  @@index([aspect])
  @@index([layer])
}

// ============================================================
// SURVEY RESPONSE — jawaban per pertanyaan
// ============================================================

model SurveyResponse {
  id             String  @id @default(cuid())
  questionId     String
  questionCode   String  // denormalized for easy querying, e.g. "A1.1"
  respondentRole String  // "PARENT" | "NANNY"

  // Linked to a profile (standalone survey fill — the primary use)
  parentProfileId String?
  nannyProfileId  String?

  // Optionally linked to a matching request (in-context scoring)
  matchingRequestId String?

  answerValue   String?  // kode pilihan, e.g. "a", "b"
  answerText    String?  @db.Text  // free-text answer
  popupAnswers  Json?    // {trigger_idx: "a", ...}
  isDealbreaker Boolean  @default(false)
  score         Float?   // computed score per answer (0–100)

  createdAt DateTime @default(now())

  question        SurveyQuestion   @relation(fields: [questionId], references: [id])
  parentProfile   ParentProfile?   @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  nannyProfile    NannyProfile?    @relation(fields: [nannyProfileId], references: [id], onDelete: Cascade)
  matchingRequest MatchingRequest? @relation(fields: [matchingRequestId], references: [id], onDelete: Cascade)

  // One answer per question per respondent per profile
  @@unique([questionId, respondentRole, parentProfileId])
  @@unique([questionId, respondentRole, nannyProfileId])
  @@index([parentProfileId])
  @@index([nannyProfileId])
  @@index([matchingRequestId])
  @@index([questionCode])
}

// ============================================================
// CUSTOM QUESTION — pertanyaan tambahan dari parent/nanny
// ============================================================

model CustomQuestion {
  id                String   @id @default(cuid())
  matchingRequestId String
  askedByRole       String   // "PARENT" atau "NANNY"
  questionText      String   @db.Text
  isDealbreaker     Boolean  @default(false)
  answerFromParent  String?  @db.Text
  answerFromNanny   String?  @db.Text
  isAnswered        Boolean  @default(false)
  createdAt         DateTime @default(now())

  matchingRequest MatchingRequest @relation(fields: [matchingRequestId], references: [id], onDelete: Cascade)

  @@index([matchingRequestId])
}

// ============================================================
// DEALBREAKER — tracking per aspek
// ============================================================

model Dealbreaker {
  id                String   @id @default(cuid())
  matchingRequestId String
  questionCode      String   // kode pertanyaan (A1-01, custom, dll)
  flaggedByRole     String   // "PARENT" atau "NANNY"
  isMatched         Boolean? // null = belum dicek, true/false = hasil
  notificationSent  Boolean  @default(false)
  createdAt         DateTime @default(now())

  matchingRequest MatchingRequest @relation(fields: [matchingRequestId], references: [id], onDelete: Cascade)

  @@index([matchingRequestId])
}

// ============================================================
// MATCHING RESULT — output AI scoring
// ============================================================

model MatchingResult {
  id                String   @id @default(cuid())
  matchingRequestId String   @unique
  nannyProfileId    String

  // Scores per domain
  scoreOverall      Float    // 0–100
  scoreDomainA      Float?   // Kondisi Kerja
  scoreDomainB      Float?   // Nilai & Gaya Hidup
  scoreDomainC      Float?   // Pengalaman & Kemampuan

  // Detail breakdown (JSON untuk fleksibilitas)
  aspectBreakdown   Json?    // {A1: 85, A2: 70, B1: 90, ...}
  matchHighlights   String[] // area cocok
  mismatchAreas     String[] // area tidak cocok
  negotiationPoints String[] // pertanyaan untuk negosiasi
  tipsForParent     String[] // saran untuk orang tua
  tipsForNanny      String[] // saran untuk nanny

  // AI raw output
  aiRawOutput       Json?    // full response dari Claude API
  aiModel           String?  // model yang dipakai
  generatedAt       DateTime @default(now())

  // Report PDF
  reportPdfUrl      String?  // URL ke file PDF
  reportGeneratedAt DateTime?

  matchingRequest MatchingRequest @relation(fields: [matchingRequestId], references: [id], onDelete: Cascade)
  nannyProfile    NannyProfile   @relation(fields: [nannyProfileId], references: [id])

  @@index([nannyProfileId])
}

// ============================================================
// NANNY ASSIGNMENT — saat nanny mulai kerja
// ============================================================

model NannyAssignment {
  id              String    @id @default(cuid())
  parentProfileId String
  nannyProfileId  String
  startDate       DateTime
  endDate         DateTime?
  isActive        Boolean   @default(true)
  nannyType       NannyType
  salaryAgreed    Int?      // IDR/bulan
  notes           String?   @db.Text
  endReason       String?   @db.Text // alasan penugasan berakhir — diisi saat diakhiri
  fromGuarantee   Boolean   @default(false) // penempatan hasil klaim Jaminan Kecocokan (tidak menerbitkan jaminan baru)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  parentProfile ParentProfile @relation(fields: [parentProfileId], references: [id])
  nannyProfile  NannyProfile  @relation(fields: [nannyProfileId], references: [id])

  // Evaluations linked to this assignment
  evaluations Evaluation[]

  // Check-ins
  checkins         Checkin[]

  // Anak-anak yang ditangani nanny dalam penugasan ini
  assignedChildren AssignmentChild[]

  @@index([parentProfileId])
  @@index([nannyProfileId])
  @@index([isActive])
}

// ============================================================
// ASSIGNMENT CHILD — many-to-many NannyAssignment ↔ ChildProfile
// ============================================================

model AssignmentChild {
  assignmentId   String
  childProfileId String
  isPrimary      Boolean  @default(false)
  assignedAt     DateTime @default(now())

  assignment   NannyAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  childProfile ChildProfile    @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  @@id([assignmentId, childProfileId])
  @@index([assignmentId])
  @@index([childProfileId])
}

// ============================================================
// CHECKIN — check-in singkat minggu ke-1 & ke-2
// ============================================================

model Checkin {
  id               String          @id @default(cuid())
  assignmentId     String
  timing           EvaluationTiming
  status           CheckinStatus   @default(PENDING)

  // Parent responses
  parentConditionRating  String?   // "Sangat baik" / "Baik" / "Cukup" / "Ada kendala"
  parentConcernFlag      String?   // "Tidak ada" / "Ada, masih bisa kutangani" / "Ada, perlu bantuan"
  parentAdaptRating      String?
  parentCommsRating      String?
  parentFreeText         String?   @db.Text

  // Nanny responses
  nannyConditionRating   String?
  nannyConcernFlag       String?
  nannyComfortRating     String?
  nannyCommsRating       String?
  nannyFreeText          String?   @db.Text

  parentDoneAt  DateTime?
  nannyDoneAt   DateTime?
  scheduledAt   DateTime
  createdAt     DateTime  @default(now())

  assignment NannyAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
}

// ============================================================
// EVALUATION — evaluasi bulanan / berkala
// ============================================================

model Evaluation {
  id              String           @id @default(cuid())
  assignmentId    String
  parentProfileId String
  nannyProfileId  String
  timing          EvaluationTiming
  status          EvaluationStatus @default(PENDING)

  // Parent fills
  parentScores       Json?          // {ketepatan_waktu: 4, kebersihan: 5, ...}
  parentNarrative    String?        @db.Text
  parentRecommend    Boolean?
  parentContinue     Boolean?       // lanjut atau ganti nanny?

  // Nanny fills
  nannyScores        Json?          // {kondisi_kerja: 4, komunikasi: 5, ...}
  nannyNarrative     String?        @db.Text
  nannyContinue      Boolean?       // mau lanjut atau tidak?

  // AI summary
  aiSummary          String?        @db.Text
  aiRecommendation   String?        @db.Text

  // Report
  reportPdfUrl       String?
  reportGeneratedAt  DateTime?

  parentDoneAt  DateTime?
  nannyDoneAt   DateTime?
  scheduledAt   DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignment    NannyAssignment @relation(fields: [assignmentId], references: [id])
  parentProfile ParentProfile   @relation(fields: [parentProfileId], references: [id])
  nannyProfile  NannyProfile    @relation(fields: [nannyProfileId], references: [id])

  @@index([assignmentId])
  @@index([parentProfileId])
  @@index([nannyProfileId])
}

// ============================================================
// ASSESSMENT RESULT — psikotes (Layer 2) & laporan psikolog (Layer 3)
// ============================================================

model AssessmentResult {
  id             String          @id @default(cuid())
  nannyProfileId String
  layer          AssessmentLayer
  transactionId  String?

  // Layer 2 — AI psikotes
  testType       String?         // "IQ", "KEPRIBADIAN", "SIKAP_KERJA"
  rawScores      Json?
  interpretedBy  String?         @default("AI")

  // Layer 3 — Psikolog
  psychologistId String?         // user ID psikolog HCC
  clinicalNotes  String?         @db.Text
  verdict        String?         // "Direkomendasikan" / "Perlu Catatan" / dll
  parentMessage  String?         @db.Text  // pesan untuk orang tua
  grafisNotes    Json?           // {relasi_anak: "Tinggi", relasi_sekitar: "Cukup", ...}

  // NannyCare Profile PDF (output dari ReportLab Python service)
  reportPdfUrl   String?
  reportGeneratedAt DateTime?

  issuedAt       DateTime        @default(now())
  createdAt      DateTime        @default(now())

  nannyProfile NannyProfile @relation(fields: [nannyProfileId], references: [id], onDelete: Cascade)

  @@index([nannyProfileId])
  @@index([layer])
}

// ============================================================
// TRACK RECORD — rekam jejak anonim antar keluarga
// ============================================================

model TrackRecordEntry {
  id             String   @id @default(cuid())
  nannyProfileId String
  reviewerName   String?  // anonim kecuali opt-in
  isPublic       Boolean  @default(false)
  rating         Int      // 1–5
  workPeriod     String?
  durationMonths Int?
  reviewText     String?  @db.Text
  isVerified     Boolean  @default(false)

  // Link ke penugasan nyata — sumber verifikasi (review hanya dari keluarga yang benar-benar mempekerjakan)
  parentProfileId String?
  assignmentId    String?  @unique

  createdAt      DateTime @default(now())

  nannyProfile  NannyProfile   @relation(fields: [nannyProfileId], references: [id], onDelete: Cascade)
  parentProfile ParentProfile? @relation(fields: [parentProfileId], references: [id])

  @@index([nannyProfileId])
  @@index([parentProfileId])
}

// ============================================================
// MATCH GUARANTEE — Jaminan Kecocokan (PRD 06 §5, Juli 2026)
// Nanny berhenti ≤30 hari pertama → matching ulang tanpa kuota
// + penempatan ulang gratis penuh. 1× per penempatan.
// ============================================================

model MatchGuarantee {
  id                  String    @id @default(cuid())
  parentProfileId     String
  sourceAssignmentId  String    @unique // penugasan yang berakhir ≤30 hari
  status              String    @default("AVAILABLE") // AVAILABLE | USED
  reason              String?   @db.Text // alasan berhenti (dari endReason)
  usedAt              DateTime?
  usedForAssignmentId String?   // penugasan baru hasil klaim jaminan
  createdAt           DateTime  @default(now())

  parentProfile ParentProfile @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)

  @@index([parentProfileId, status])
}

model TrackRecordAccess {
  id              String   @id @default(cuid())
  parentProfileId String
  nannyProfileId  String   // nanny yang rekam jejaknya dibeli
  transactionId   String?
  accessGrantedAt DateTime @default(now())
  expiresAt       DateTime // akses berlaku berapa lama

  parentProfile ParentProfile @relation(fields: [parentProfileId], references: [id])

  @@index([parentProfileId])
  @@index([nannyProfileId])
}

// ============================================================
// REFERRAL — sistem referral nanny
// ============================================================

model Referral {
  id              String    @id @default(cuid())
  referrerNannyId String    // nanny yang mereferral
  referredNannyId String?   // nanny yang direferral (jika sudah daftar)
  parentProfileId String?   // keluarga yang menerima nanny
  status          String    @default("PENDING") // "PENDING", "HIRED", "MONTH_1", "MONTH_3"

  // Bonus tracking
  bonusReferrerIDR Int?
  bonusNannyIDR    Int?
  bonusPaidAt      DateTime?

  // Milestone dates
  hiredAt          DateTime?
  month1At         DateTime?
  month3At         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referrerNanny NannyProfile @relation("ReferrerNanny", fields: [referrerNannyId], references: [id])

  @@index([referrerNannyId])
  @@index([referredNannyId])
}

// ============================================================
// NANNY MEDIA — foto & video portfolio nanny
// Foto: Cloudflare R2 (storageKey = R2 object key)
// Video: Cloudflare Stream (storageKey = Stream UID)
// ============================================================

model NannyMedia {
  id             String         @id @default(cuid())
  nannyProfileId String
  type           NannyMediaType
  storageKey     String         // R2 key (foto) atau Stream UID (video)
  storageMB      Float?         // ukuran file dalam MB — untuk monitoring kuota
  durationSec    Int?           // durasi video dalam detik (max 180)
  slug           String?        // "perkenalan", "gendong-bayi", "masakan-1"
  sortOrder      Int            @default(0)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())

  nannyProfile NannyProfile @relation(fields: [nannyProfileId], references: [id], onDelete: Cascade)

  @@index([nannyProfileId])
  @@index([type])
}

// ============================================================
// NANNY PORTFOLIO — entri pengalaman kerja (teks + foto opsional)
// ============================================================

model NannyPortfolio {
  id             String   @id @default(cuid())
  nannyProfileId String
  title          String
  description    String?  @db.VarChar(500)
  startMonth     Int
  startYear      Int
  endMonth       Int?
  endYear        Int?
  isOngoing      Boolean  @default(false)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  nannyProfile NannyProfile          @relation(fields: [nannyProfileId], references: [id], onDelete: Cascade)
  media        NannyPortfolioMedia[]

  @@index([nannyProfileId])
}

model NannyPortfolioMedia {
  id          String   @id @default(cuid())
  portfolioId String
  storageKey  String   // R2 key
  url         String   // R2 public URL
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  portfolio NannyPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
}

// ============================================================
// CONNECTION QUOTA — kuota koneksi parent (rolling 30-day window)
// Gratis: 3 referral/bulan · Langganan: 3 referral + 7 talent pool
// ============================================================

model ConnectionQuota {
  id              String   @id @default(cuid())
  parentProfileId String
  periodStart     DateTime // awal window 30 hari
  periodEnd       DateTime // periodStart + 30 hari

  // Penggunaan per flow
  referralUsed    Int      @default(0)  // max 3 (gratis) atau 3 (langganan)
  talentPoolUsed  Int      @default(0)  // max 0 (gratis) atau 7 (langganan)

  // Batas berdasarkan status langganan saat period dibuat
  referralLimit   Int      @default(3)
  talentPoolLimit Int      @default(0)  // 0 jika tidak berlangganan

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parentProfile ParentProfile @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)

  @@index([parentProfileId])
  @@index([periodEnd])
}

// ============================================================
// NOTIFICATION
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String   @db.Text
  type      String   // "MATCHING_READY", "EVALUATION_DUE", "DEALBREAKER", "PAYMENT", dll
  isRead    Boolean  @default(false)
  link      String?  // deep link ke halaman terkait
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

// ============================================================
// ACTIVITY LOG — audit trail
// ============================================================

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // "LOGIN", "SURVEY_SUBMITTED", "REPORT_DOWNLOADED", dll
  entity    String?  // "MatchingRequest", "Evaluation", dll
  entityId  String?
  metadata  Json?    // data tambahan (IP, browser, dll)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ============================================================
// PARENT REFERRAL — parent merekomendasikan orang tua / nanny lain
// ============================================================

model ParentReferral {
  id            String    @id @default(cuid())
  referrerId    String    // parentProfile yang mereferral
  refereeType   String    // "PARENT" | "NANNY"
  refereeName   String?
  refereePhone  String?
  status        String    @default("PENDING") // "PENDING" | "REGISTERED" | "DEAL" | "PAID"
  bonusIDR      Int?
  bonusPaidAt   DateTime?
  dealAt        DateTime?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  referrer ParentProfile @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}

// ============================================================
// MATCH RESULT — cache skor kecocokan untuk direktori nanny (Sprint 2)
// Berbeda dari MatchingResult: ini direct cache tanpa MatchingRequest
// ============================================================

model MatchResult {
  id              String    @id @default(cuid())
  parentProfileId String
  nannyProfileId  String

  parentProfile   ParentProfile @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  nannyProfile    NannyProfile  @relation(fields: [nannyProfileId], references: [id], onDelete: Cascade)

  // Skor 0–100
  skorKeseluruhan Int
  skorDomainA     Int?
  skorDomainB     Int?
  skorDomainC     Int?

  // Narasi dari Claude API
  kekuatan        String[]  @default([])
  potensiLemah    String[]  @default([])
  potensiKonflik  String[]  @default([])
  caraMengatasi   String[]  @default([])
  tipsOrangTua    String[]  @default([])
  tipsNanny       String[]  @default([])

  // Dealbreaker
  dealbreakerFlags Json?
  adaDealbreaker  Boolean   @default(false)

  // Status koneksi (Kuota Koneksi)
  kontakTerbuka         Boolean            @default(false)
  flowType              ConnectionFlowType?  // REFERRAL atau TALENT_POOL
  quotaUsed             Boolean            @default(false)  // pakai kuota (true) atau bayar langsung (false)
  koneksiDilakukanAt    DateTime?

  // Psikotes AI (Layer 2) — orang tua bayar sekali untuk buka hasil detail nanny ini (permanen, tidak expire)
  psikotesUnlocked      Boolean            @default(false)
  psikotesUnlockedAt    DateTime?

  // Cache — tidak perlu hit Claude API tiap kali
  generatedAt     DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([parentProfileId, nannyProfileId])
  @@index([parentProfileId])
  @@index([nannyProfileId])
}

// ============================================================
// OTP TOKEN — untuk reset password via WA
// ============================================================

model OtpToken {
  id        String   @id @default(cuid())
  phone     String
  code      String
  type      String   @default("RESET_OTP") // "RESET_OTP" | "RESET_SESSION"
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, type])
}

// ============================================================
// PRICING CONFIG ENTRY — Panel Konfigurasi Harga & Kuota (ADR-008)
// Insert-only, tidak pernah diubah/dihapus setelah effectiveFrom lewat —
// tabel ini SEKALIGUS menjadi log audit. "cancelled" hanya boleh diisi
// selama effectiveFrom masih di masa depan (batal sebelum berlaku).
// Nilai efektif pada waktu T = entry non-cancelled dengan effectiveFrom
// terbaru yang <= T. Kalau belum ada entry sama sekali untuk key tsb,
// fallback ke DEFAULT_PRICING di src/lib/pricing-config.ts.
// ============================================================

model PricingConfigEntry {
  id            String           @id @default(cuid())
  key           PricingConfigKey
  value         Int              // IDR untuk harga; jumlah untuk kuota
  effectiveFrom DateTime         // mulai berlaku — tidak boleh di masa lalu saat dibuat
  reason        String           @db.Text // wajib diisi

  cancelled         Boolean   @default(false)
  cancelledAt       DateTime?
  cancelledByUserId String?

  createdByUserId String
  createdAt       DateTime @default(now())

  createdBy   User  @relation("PricingConfigScheduledBy", fields: [createdByUserId], references: [id])
  cancelledBy User? @relation("PricingConfigCancelledBy", fields: [cancelledByUserId], references: [id])

  @@index([key, effectiveFrom])
}
