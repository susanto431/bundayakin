# Email — Resend
RESEND_API_KEY=

# WhatsApp OTP — Fonnte
FONNTE_API_TOKEN=

# PDF Service — Railway
PDF_SERVICE_URL=
PDF_SERVICE_SECRET=

# Cloudflare R2 — foto (avatar, portfolio nanny)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_TOKEN=
R2_BUCKET_NAME=bundayakin-media
R2_ENDPOINT=
R2_PUBLIC_URL=https://media.bundayakin.com

# Cloudflare Stream — video (perkenalan & keahlian nanny)
CLOUDFLARE_STREAM_TOKEN=
CLOUDFLARE_STREAM_WEBHOOK_SECRET=   # dari CF Stream dashboard → Webhooks → Secret

# App
NEXT_PUBLIC_APP_URL=https://bundayakin.com

# Cron — Vercel Cron (lihat vercel.json). Isi dengan string acak; Vercel otomatis
# mengirimkannya sebagai header Authorization: Bearer <CRON_SECRET> ke job terjadwal.
CRON_SECRET=

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
